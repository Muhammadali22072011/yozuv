# App environment: "development" | "production"
# When APP_ENV=production, SECRET_KEY must be >=32 chars and non-default.
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://api.yourdomain.com/api/telegram/webhook
# Shared secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token.
# Must be set in production (>=16 chars). Generate with:
#   python -c "import secrets; print(secrets.token_hex(16))"
WEBHOOK_SECRET=

# JWT
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# PayTechUZ (paytechuz package may require license key — see docs)
PAYTECH_LICENSE_API_KEY=

# Payments
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_MERCHANT_USER_ID=your_click_merchant_user_id
CLICK_SECRET_KEY=your_click_secret_key

# App URLs (for QR, PDF, CORS). In production use HTTPS subdomains.
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Admin Telegram user IDs, comma-separated
ADMIN_TELEGRAM_IDS=

# Uploads directory (absolute path inside container/VM)
UPLOADS_DIR=/tmp/yozuv_uploads

# Frontend (Next.js) — only NEXT_PUBLIC_* vars are exposed to browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BOT_USERNAME=Yozuv_cl_bot

# Nightly DB backup -> S3-compatible bucket (AWS, Backblaze B2,
# Cloudflare R2, MinIO). Leave BACKUP_S3_BUCKET blank to disable.
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=yozuv/backups/
# AWS S3: leave BACKUP_S3_ENDPOINT_URL blank.
# B2:     https://s3.<region>.backblazeb2.com
# R2:     https://<accountid>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_RETENTION_DAYS=30
